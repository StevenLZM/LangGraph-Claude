# Application
APP_NAME=production-agent-customer-service
APP_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8000

# M0 runs without real model calls. Later milestones can switch this to primary/fallback providers.
LLM_MODE=offline_stub
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PRIMARY_MODEL=claude-sonnet-4-6
FALLBACK_MODEL=gpt-4o-mini

# Storage and cache. Empty values mean "not configured" in M0 health checks.
REDIS_URL=
DATABASE_URL=
CHECKPOINTER_DB=./data/sessions.db
MEMORY_DB=./data/memory.db

# Observability
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=production-agent-customer-service
