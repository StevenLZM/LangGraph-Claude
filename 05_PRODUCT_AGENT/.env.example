# Application
APP_NAME=production-agent-customer-service
APP_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8000

# M6 real LLM path uses DeepSeek through an OpenAI-compatible endpoint.
# The runtime requires a real LLM; tests inject a fake client instead of using offline_stub.
LLM_MODE=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MAX_MODEL=deepseek-v4-pro
DEEPSEEK_LIGHT_MODEL=deepseek-v4-flash
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
PRIMARY_MODEL=claude-sonnet-4-6
FALLBACK_MODEL=gpt-4o-mini

# Storage and cache. Empty REDIS_URL uses in-memory rate limiting for local pytest.
REDIS_URL=
DATABASE_URL=
STORAGE_BACKEND=sqlite
CHECKPOINTER_BACKEND=none
CHECKPOINTER_URL=
CHECKPOINTER_SETUP=true
CHECKPOINTER_DB=./data/sessions.db
MEMORY_DB=./data/memory.db
CHAT_REQUEST_DB=./data/chat_requests.db
MESSAGE_OUTBOX_DB=./data/message_outbox.db

# RocketMQ business messaging. Local pytest keeps it disabled; Docker Compose
# enables it to demonstrate production MQ features.
ROCKETMQ_ENABLED=false
ROCKETMQ_ENDPOINT=localhost:9876
ROCKETMQ_PRODUCER_GROUP=PID_05_PRODUCT_AGENT
ROCKETMQ_ACCESS_KEY=
ROCKETMQ_SECRET_KEY=
ROCKETMQ_NORMAL_TOPIC=agent-customer-service-normal-v1
ROCKETMQ_FIFO_TOPIC=agent-customer-service-fifo-v1
ROCKETMQ_DELAY_TOPIC=agent-customer-service-delay-v1
ROCKETMQ_TRANSACTION_TOPIC=agent-customer-service-tx-v1

# M3 rate limits and token budgets
USER_RATE_LIMIT_PER_MINUTE=10
GLOBAL_QPS_LIMIT=100
SINGLE_REQUEST_TOKEN_BUDGET=4000
GLOBAL_HOURLY_TOKEN_BUDGET=500000

# Observability. Set LANGCHAIN_TRACING_V2=true and fill LANGCHAIN_API_KEY
# before docker compose up if you want the project to appear in LangSmith.
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=production-agent-customer-service
OBSERVABILITY_ENV=local
QUALITY_ALERT_THRESHOLD=70

# M5 Docker Compose
POSTGRES_PASSWORD=customer_service
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
