# Application
APP_NAME=production-agent-customer-service
APP_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8000

# M3 still runs locally without real model calls. Later milestones can switch the chat path to providers.
LLM_MODE=offline_stub
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PRIMARY_MODEL=claude-sonnet-4-6
FALLBACK_MODEL=gpt-4o-mini

# Storage and cache. Empty REDIS_URL uses in-memory M3 rate limiting for local development.
REDIS_URL=
DATABASE_URL=
CHECKPOINTER_DB=./data/sessions.db
MEMORY_DB=./data/memory.db

# M3 rate limits and token budgets
USER_RATE_LIMIT_PER_MINUTE=10
GLOBAL_QPS_LIMIT=100
SINGLE_REQUEST_TOKEN_BUDGET=4000
GLOBAL_HOURLY_TOKEN_BUDGET=500000

# Observability
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=production-agent-customer-service
