# ══════════════════════════════════════════════════════════════════
# InsightLoop — Multi-Agent Deep Research System
# 环境变量示例。复制为 .env 后填入真实值（.env 已在 .gitignore 中）
# ═══════════════��══════════════════════════════════════════════════

# ── DeepSeek（LLM）────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MAX_MODEL=deepseek-v4-pro
DEEPSEEK_LIGHT_MODEL=deepseek-v4-flash

# ── DashScope（搜索 / Embedding）──────────────────────────────────
# 访问 https://bailian.console.aliyun.com/ 获取 API Key
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OpenAI 兼容端点（仅保留给 DashScope 兼容调用/旧实验）
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── 模型选型 ─────────────────────────────────────────────────────
# DashScope 旧模型选型（当前 LLM 默认不使用，搜索/Embedding 保留）
QWEN_MAX_MODEL=qwen-max
QWEN_LIGHT_MODEL=qwen-plus
# Embedding（复用 01_RAG 时需要）
QWEN_EMBEDDING_MODEL=text-embedding-v3

# ── 工具 API Keys ────────────────────────────────────────────────
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx   # 可选，提升 GitHub API 速率限制
BRAVE_API_KEY=BSA-xxxxxxxxxxxxxxxxxxxxxxxx     # 可选，MCP Brave Search 兜底

# ── LangSmith 可观测性（可选）────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__xxxxxxxxxxxxxxxxxxxxx
LANGCHAIN_PROJECT=insightloop-multi-agent

# ── 路径配置 ───────────────────────────────────��──────────────────
DOCUMENTS_DIR=./data/documents
VECTORSTORE_DIR=./data/vectorstore
REPORTS_DIR=./data/reports
ARCHIVE_DB=./data/archive.db
CHECKPOINTER_DB=./data/checkpoints.db

# ── 研究流程参数 ─────────────────────────────────────────────────
MAX_REFLECTION_ITERATIONS=3
DEFAULT_RESEARCH_DEPTH=standard   # quick / standard / deep
MAX_PARALLEL_RESEARCHERS=4
RESEARCH_TIMEOUT_SECONDS=180

# ── RAG 参数（复用 01_RAG 约定）──────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50
SEMANTIC_TOP_K=6
BM25_TOP_K=6
FINAL_TOP_K=4
SEMANTIC_WEIGHT=0.6
SIMILARITY_THRESHOLD=0.3

# ── FastAPI 服务 ─────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
SSE_RETRY_MS=3000

# ── Streamlit 服务 ────────────────────────────────────────────────
STREAMLIT_HOST=0.0.0.0
STREAMLIT_PORT=8501
# Streamlit 前端访问 FastAPI 的地址；Docker Compose 内自动设为 http://api:8080
INSIGHTLOOP_API=http://localhost:8080
# 旧变量名，仍兼容
API_BASE_URL=http://localhost:8080
